# Environment Variables — Marketing Ops Center
# Copy to .env and fill in values

# Database
DB_PATH=./data/ops_dashboard.db

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Encryption keys for sensitive data (AES-256-GCM)
API_CREDENTIALS_KEY=
ARTIST_BANK_KEY=

# Server
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Telegram Bot (Phase 4)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_VIDEOGRAPHER_CHAT_ID=
TELEGRAM_SMM_CHAT_ID=
WEBSITE_URL=http://localhost:3000

# Google Calendar (Phase 5)
GOOGLE_CALENDAR_SERVICE_ACCOUNT_KEY=

# Instagram Graph API (Phase 8)
# YouTube Data API (Phase 8)

# OpenClaw
# Hook endpoint OpenClaw is listening on for trigger requests (POST /hooks/agent).
# Local default assumes OpenClaw is running on the same machine. For a remote
# OpenClaw instance reachable only via Tailscale, use its Tailscale Serve URL,
# e.g. https://<machine>.<tailnet>.ts.net/hooks/agent — this requires the
# Hyphening server to also be joined to that same Tailscale network.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/hooks/agent
# Bearer token OpenClaw validates against its hooks.token config (NOT its
# gateway.auth.token, which is for the Control UI/WebSocket — different value).
OPENCLAW_HOOK_TOKEN=
# Shared secret used to verify HMAC-SHA256 signatures on inbound webhooks from
# OpenClaw at /api/openclaw/webhook. Must match the value OpenClaw signs with.
OPENCLAW_HMAC_SECRET=
